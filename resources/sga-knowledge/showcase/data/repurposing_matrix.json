  "productionWorkflow": {
    "phases": [
      {
        "phase": "Capture",
        "day": "Tuesday",
        "tasks": "Film pillar video or draft pillar article. Record all raw footage/notes."
      },
      {
        "phase": "Process",
        "day": "Wednesday",
        "tasks": "Edit long-form video. Extract clips for Shorts/Reels. Create thumbnails."
      },
      {
        "phase": "Adapt",
        "day": "Thursday AM",
        "tasks": "Create platform-specific versions. Write captions. Design carousels."
      },
      {
        "phase": "Schedule",
        "day": "Thursday PM",
        "tasks": "Queue all assets across platforms. Set publish times per platform best practices."
      },
      {
        "phase": "Publish & Engage",
        "day": "Friday-Monday",
        "tasks": "Assets publish on schedule. Monitor comments, respond, boost top performers."
      }
    ]
  }
